<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Add Blog | BlogSpace</title>

    <%- include('./partials/head.ejs') %>

</head>

<body>

<%- include('./partials/nav.ejs') %>

<div class="container">

    <div class="card center-card" style="max-width:800px;">

        <h1 class="page-title">
            Create New Blog
        </h1>

        <p
        class="subtitle"
        style="margin-bottom:35px;">

            Share your thoughts with the BlogSpace community.

        </p>

        <form
        action="/blogs/add"
        method="POST">

            <!-- Blog Title -->

            <div class="form-group">

                <label>
                    Blog Title
                </label>

                <input
                type="text"
                name="blogtitle"
                placeholder="Enter your blog title"
                required>

            </div>

            <!-- Thumbnail -->

            <div class="form-group">

                <label>
                    Thumbnail URL
                </label>

                <input
                type="text"
                name="blogThumb"
                placeholder="https://example.com/image.jpg"
                required>

            </div>

            <!-- Description -->

            <div class="form-group">

                <label>
                    Blog Content
                </label>

                <textarea
                name="blogDes"
                rows="12"
                placeholder="Write your blog here..."
                required></textarea>

            </div>

            <div
            style="
            display:flex;
            justify-content:flex-end;
            gap:15px;
            flex-wrap:wrap;">

                <a href="/blogs/index">

                    <button
                    type="button"
                    class="btn btn-outline">

                        Cancel

                    </button>

                </a>

                <button
                type="submit"
                class="btn">

                    Publish Blog →

                </button>

            </div>

        </form>

    </div>

</div>

<footer>

    <p>

        BlogSpace • Every story deserves to be shared.

    </p>

</footer>

</body>

</html>