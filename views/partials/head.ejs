<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{
    --black:#0B0909;
    --forest:#2E4540;
    --teal:#408175;
    --lavender:#B5B9F0;

    --surface:#131918;
    --card:#1A2220;
    --border:#253430;

    --text:#E8EBE9;
    --muted:#74857F;

    --sans:'Inter',sans-serif;
    --mono:'JetBrains Mono',monospace;

    --radius:12px;
}

body{
    background:var(--black);
    color:var(--text);
    font-family:var(--sans);
}

a{
    color:inherit;
    text-decoration:none;
}

.container{
    width:min(1150px,92%);
    margin:auto;
}

.page-title{
    font-size:2rem;
    margin-bottom:12px;
    font-weight:600;
}

.subtitle{
    color:var(--muted);
    line-height:1.7;
}

.card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:16px;
    padding:28px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
}

input,
textarea{
    width:100%;
    background:var(--black);
    border:1px solid var(--border);
    color:var(--text);
    padding:14px 18px;
    border-radius:10px;
    font-family:var(--mono);
    outline:none;
    transition:.2s;
}

input:focus,
textarea:focus{
    border-color:var(--teal);
    box-shadow:0 0 0 3px rgba(64,129,117,.18);
}

textarea{
    resize:vertical;
    min-height:180px;
}

label{
    display:block;
    margin-bottom:8px;
    color:var(--muted);
    text-transform:uppercase;
    font-size:.75rem;
    letter-spacing:.1em;
    font-weight:600;
}

.form-group{
    margin-bottom:20px;
}

.btn{
    background:var(--teal);
    color:white;
    border:none;
    border-radius:10px;
    padding:13px 25px;
    cursor:pointer;
    transition:.2s;
    font-size:.9rem;
}

.btn:hover{
    background:#4d9787;
}

.btn-outline{
    background:transparent;
    color:var(--muted);
    border:1px solid var(--border);
}

.btn-outline:hover{
    color:var(--lavender);
    border-color:var(--lavender);
}

.blog-card{
    overflow:hidden;
    transition:.25s;
}

.blog-card:hover{
    transform:translateY(-5px);
}

.blog-card img{
    width:100%;
    height:220px;
    object-fit:cover;
    border-radius:10px;
}

.blog-title{
    font-size:1.25rem;
    margin:18px 0 12px;
    font-weight:600;
}

.blog-desc{
    color:var(--muted);
    line-height:1.6;
}

.comment{
    margin-top:15px;
}

.comment-author{
    color:var(--lavender);
    margin-bottom:8px;
    font-weight:600;
}

.comment-text{
    color:var(--muted);
}

.center-card{
    max-width:520px;
    margin:70px auto;
}

.hero{
    max-width:900px;
    margin:60px auto;
    text-align:center;
}

.hero h1{
    font-size:3rem;
    margin-bottom:15px;
}

.hero p{
    color:var(--muted);
    line-height:1.8;
    margin-bottom:35px;
}

.button-group{
    display:flex;
    justify-content:center;
    gap:18px;
    flex-wrap:wrap;
}

.section-space{
    margin-top:40px;
}

footer{
    margin-top:70px;
    color:var(--muted);
    text-align:center;
    padding-bottom:30px;
}

@media(max-width:700px){

.hero h1{
font-size:2.2rem;
}

nav{
flex-direction:column;
gap:15px;
}

}
</style>