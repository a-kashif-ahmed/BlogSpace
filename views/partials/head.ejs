<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">

<style>

*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{

    

    --bg:#F7F1DE;
    --surface:#FFFDF7;
    --surface-2:#F1E8CF;

    --primary:#9D6638;
    --primary-hover:#874F23;

    --secondary:#B0BA99;

    --accent:#000000;

    --border:#D7CCB2;

    --text:#3A2416;

    --muted:#6F665C;

    --success:#4F7D4F;

    --radius:16px;

    --shadow:
    0 12px 30px rgba(78,34,15,.08);

    --sans:'Inter',sans-serif;

    --mono:'JetBrains Mono',monospace;

}



body{

    background:var(--bg);

    color:var(--text);

    font-family:var(--sans);

    line-height:1.7;

}



a{

    color:var(--primary);

    text-decoration:none;

    transition:.2s;

}

a:hover{

    color:var(--accent);

}



.container{

    width:min(1150px,92%);

    margin:auto;

}



.page-title{

    font-size:2.2rem;

    font-weight:700;

    color:var(--accent);

    margin-bottom:10px;

}

.subtitle{

    color:var(--muted);

    line-height:1.8;

}



.card{

    background:var(--surface);

    border:1px solid var(--border);

    border-radius:18px;

    padding:30px;

    box-shadow:var(--shadow);

    transition:.25s;

}

.card:hover{

    transform:translateY(-4px);

}



.grid{

    display:grid;

    grid-template-columns:

    repeat(auto-fit,minmax(300px,1fr));

    gap:28px;

}



input,
textarea{

    width:100%;

    background:white;

    border:1px solid var(--border);

    color:var(--text);

    padding:15px 18px;

    border-radius:12px;

    font-family:var(--mono);

    outline:none;

    transition:.2s;

}

input::placeholder,
textarea::placeholder{

    color:#998F84;

}

input:focus,
textarea:focus{

    border-color:var(--primary);

    box-shadow:

    0 0 0 4px rgba(157,102,56,.15);

}



textarea{

    resize:vertical;

    min-height:180px;

}



label{

    display:block;

    margin-bottom:8px;

    color:var(--accent);

    font-size:.75rem;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-weight:700;

}



.form-group{

    margin-bottom:22px;

}



.btn{

    background:var(--primary);

    color:white;

    border:none;

    border-radius:12px;

    padding:14px 28px;

    cursor:pointer;

    font-weight:600;

    transition:.25s;

}

.btn:hover{

    background:var(--primary-hover);

}



.btn-outline{

    background:transparent;

    color:var(--primary);

    border:2px solid var(--primary);

}

.btn-outline:hover{

    background:var(--primary);

    color:white;

}



.blog-card{

    overflow:hidden;

}

.blog-card img{

    width:100%;

    height:220px;

    object-fit:cover;

    border-radius:12px;

    margin-bottom:20px;

}

.blog-title{

    color:var(--accent);

    font-size:1.45rem;

    font-weight:700;

    margin-bottom:12px;

}

.blog-desc{

    color:var(--muted);

    line-height:1.8;

}



.comment{

    margin-top:20px;

    border-left:5px solid var(--primary);

}

.comment-author{

    color:var(--primary);

    font-weight:700;

    margin-bottom:8px;

}

.comment-text{

    color:var(--muted);

}



.center-card{

    max-width:560px;

    margin:70px auto;

}



.hero{

    max-width:900px;

    margin:60px auto;

    text-align:center;

}

.hero h1{

    font-size:3.4rem;

    color:var(--accent);

    margin-bottom:18px;

}

.hero p{

    color:var(--muted);

    max-width:700px;

    margin:0 auto 35px;

}



.button-group{

    display:flex;

    justify-content:center;

    gap:18px;

    flex-wrap:wrap;

}



.section-space{

    margin-top:50px;

}



footer{

    margin-top:70px;

    color:var(--muted);

    text-align:center;

    padding-bottom:35px;

    font-size:.95rem;

}



hr{

    border:none;

    border-top:1px solid var(--border);

    margin:35px 0;

}



::selection{

    background:var(--primary);

    color:white;

}



@media(max-width:700px){

.hero h1{

font-size:2.4rem;

}

nav{

flex-direction:column;

gap:18px;

}

}

</style>