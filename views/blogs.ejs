<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explore Blogs | BlogSpace</title>

    <%- include('./partials/head.ejs') %>
</head>

<body>

<%- include('./partials/nav.ejs') %>

<div class="container">

    <div
    style="
    display:flex;
    justify-content:space-between;
    align-items:end;
    margin-bottom:35px;
    flex-wrap:wrap;
    gap:20px;">

        <div>

            <h1 class="page-title">
                Explore Blogs
            </h1>

            <p class="subtitle">
                Read stories shared by the BlogSpace community.
            </p>

        </div>

        <a href="/blogs/add">

            <button class="btn">
                + Write Blog
            </button>

        </a>

    </div>

    <% if(bloged.length===0){ %>

        <div
        class="card"
        style="text-align:center;">

            <h2
            style="margin-bottom:15px;">
                No Blogs Yet
            </h2>

            <p class="subtitle">

                Be the first person to publish a blog on BlogSpace.

            </p>

            <br>

            <a href="/blogs/add">

                <button class="btn">
                    Publish First Blog
                </button>

            </a>

        </div>

    <% } %>

    <div class="grid">

        <% bloged.forEach(blog=>{ %>

        <div class="card blog-card">

            <img
            src="<%= blog.blogThumb %>"
            alt="<%= blog.blogtitle %>">

            <h2 class="blog-title">

                <%= blog.blogtitle %>

            </h2>

            <p
            class="blog-desc"
            style="
            margin-bottom:25px;">

                <%=
                blog.blogDes.length>130
                ?
                blog.blogDes.substring(0,130)+"..."
                :
                blog.blogDes
                %>

            </p>

            <div
            style="
            display:flex;
            justify-content:space-between;
            align-items:center;">

                <a href="/blogs/<%= blog._id %>">

                    <button class="btn">
                        Read →
                    </button>

                </a>

                <span
                style="
                color:var(--muted);
                font-size:.85rem;
                font-family:var(--mono);">

                    #<%= blog._id.toString().slice(-5) %>

                </span>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<footer>

    <p>
        BlogSpace • Share ideas with the world.
    </p>

</footer>

</body>

</html>